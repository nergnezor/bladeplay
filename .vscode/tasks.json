{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"command": "build",
			"args": ["--workspace"],
			"problemMatcher": ["$rustc"],
			"label": "cargo build",
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"label": "watch interact-logic",
			"command": "cargo watch -w interact-logic/src -x 'build -p interact-logic'",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^error",
					"file": 1,
					"line": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[Running",
					"endsPattern": "^\\[Finished"
				}
			}
		}
	]
}